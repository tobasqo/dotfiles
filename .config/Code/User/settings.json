{
    // editor
    "editor.fontLigatures": true,
    "editor.minimap.enabled": false,
    "editor.mouseWheelZoom": true,
    "editor.lineNumbers": "relative",
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorSurroundingLines": 10,
    "editor.fontSize": 15,
    "editor.rulers": [80, 88, 100],
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "modifications",
    "diffEditor.ignoreTrimWhitespace": true,
    "files.autoSave": "afterDelay",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "window.newWindowDimensions": "maximized",
    // theme
    "workbench.iconTheme": "material-icon-theme",
    "workbench.colorTheme": "GitHub Dark Dimmed",
    "editor.semanticTokenColorCustomizations": {
        "[Default Dark+]": {
            "enabled": true,
            "rules": {
                "selfParameter": "#e492de"
            }
        },
        "[GitHub Dark Dimmed]": {
            "enabled": true,
            "rules": {
                "parameter": "#adbac7",
                "variable": "#c6cdd5",
                "variable.readonly": "#77bdfb",
                "constant": "#77bdfb",
                "variable.defaultLibrary": "#c6cdd5",
                "property.defaultLibrary": "#adbac7",
                "function": "#dcbdfb",
                "module": "#c6cdd5",
                "selfParameter": "#a2d2fb",
                "class": "#faa356",
                "interface": "#faa356",
            }
        }
    },
    "workbench.colorCustomizations": {
        "[Default Dark+]": {
            "editorBracketHighlight.foreground1": "#446db4",
            "editorBracketHighlight.foreground2": "#7aa2f7",
            "editorBracketHighlight.foreground3": "#bb9af7",
            "editorBracketHighlight.foreground4": "#2ac3de",
            "editorBracketHighlight.foreground5": "#7dcfff",
            "editorBracketHighlight.foreground6": "#446db4",
        },
        "[GitHub Dark Dimmed]": {
            "editorBracketHighlight.foreground1": "#cea5fb",
            "editorBracketHighlight.foreground2": "#77bdfb",
            "editorBracketHighlight.foreground3": "#a2d2fb",
            "editorBracketHighlight.foreground4": "#7ce38b",
            "editorBracketHighlight.foreground5": "#faa356",
            "editorBracketHighlight.foreground6": "#fa7970",
        }
    },
    "editor.tokenColorCustomizations": {
        "[Default Dark+]": {
            "strings": "#86b874",
            "comments": "#636670",
            "numbers": "#ff9e64"
        },
        "[GitHub Dark Dimmed]": {
            "textMateRules": [
                {
                    "scope": "variable.parameter.function.language.special.self.python",
                    "settings": {
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "storage.type.function.async",
                    "settings": {
                        "fontStyle": "italic"
                    }
                },
                {
                    "scope": "punctuation",
                    "settings": {
                        "foreground": "#77bdfb"
                    },
                },
                {
                    "scope": "keyword.operator",
                    "settings": {
                        "foreground": "#77bdfb",
                    },
                },
                {
                    "scope": "keyword.control.flow",
                    "settings": {
                        "fontStyle": "italic",
                    },
                },
                {
                    "scope": "variable.other",
                    "settings": {
                        // "foreground": "#77bdfb",
                        // "fontStyle": "italic"
                    },
                },
            ]
        }
    },
    // git
    "git.autofetch": true,
    "git.suggestSmartCommit": false,
    // vim
    "vim.overrideCopy": true,
    "vim.useSystemClipboard": true,
    "vim.hlsearch": true,
    "vim.leader": " ",
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "k"
            ],
            "after": [
                "<ESC>",
            ]
        },
    ],
    "vim.normalModeKeyBindings": [
        {
            "before": [
                "g",
                "p",
                "d"
            ],
            "commands": [
                "editor.action.peekDefinition"
            ]
        },
        {
            "before": [
                "g",
                "i"
            ],
            "commands": [
                "editor.action.goToImplementation"
            ]
        },
        {
            "before": [
                "g",
                "p",
                "i",
            ],
            "commands": [
                "editor.action.peekImplementation"
            ]
        },
        {
            "before": [
                "g",
                "t"
            ],
            "commands": [
                "editor.action.goToTypeDefinition"
            ]
        },
        {
            "before": [
                "g",
                "p",
                "t"
            ],
            "commands": [
                "editor.action.peekTypeDefinition"
            ]
        },
        {
            "before": [
                "K"
            ],
            "commands": [
                "editor.action.showDefinitionPreviewHover"
            ]
        },
        {
            "before": [
                "<leader>",
                "c",
                "r"
            ],
            "commands": [
                "workbench.action.Rename"
            ]
        },
        {
            "before": [
                "H"
            ],
            "commands": [
                "workbench.action.previousEditor"
            ]
        },
        {
            "before": [
                "L"
            ],
            "commands": [
                "workbench.action.nextEditor"
            ]
        },
        {
            "before": [
                "<ESC><ESC>"
            ],
            "commands": [
                ":nohl"
            ]
        },
        {
            "before": [
                "[",
                "d"
            ],
            "commands": [
                "editor.action.marker.prevInFiles",
            ]
        },
        {
            "before": [
                "]",
                "d"
            ],
            "commands": [
                "editor.action.marker.nextInFiles"
            ]
        },
        {
            "before": [
                "<C-h>"
            ],
            "commands": [
                "workbench.action.focusPreviousGroup"
            ],
        },
        {
            "before": [
                "<C-l>"
            ],
            "commands": [
                "workbench.action.focusNextGroup"
            ]
        },
        {
            "before": [
                "<leader>",
                "f",
                "f"
            ],
            "commands": [
                "workbench.action.quickOpen"
            ]
        },
        {
            "before": [
                "<leader>",
                "f",
                "g"
            ],
            "commands": [
                "workbench.view.search"
            ]
        }
    ],
    "vim.operatorPendingModeKeyBindings": [
        {
            "before": [
                "H"
            ],
            "after": [
                "^"
            ]
        },
        {
            "before": [
                "L"
            ],
            "after": [
                "$"
            ]
        },
    ],
    "vim.visualModeKeyBindings": [
        {
            "before": [
                ">",
            ],
            "commands": [
                "editor.action.indentLines"
            ]
        },
        {
            "before": [
                "<"
            ],
            "commands": [
                "editor.action.outdentLines"
            ]
        }
    ],
    // python
    "python.analysis.autoImportCompletions": true,
    "python.analysis.inlayHints.callArgumentNames": "partial",
    "python.analysis.autoFormatStrings": true,
    "debugpy.showPythonInlineValues": true,
    // mypy
    "mypy.dmypyExecutable": "${workspace}/.venv/bin/dmypy",
    "mypy.runUsingActiveInterpreter": true,
    "mypy.configFile": "pyproject.toml",
    // ruff
    "ruff.configuration": "pyproject.toml",
    "python.analysis.typeEvaluation.strictListInference": true,
    "files.exclude": {
        "**/__pycache__": true,
        "**/.idea": true,
        "**/.mypy_cache": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/.venv": true
    },
    "git.confirmSync": false,
    "svelte.enable-ts-plugin": true,
    "makefile.configureOnOpen": true,
    "window.zoomLevel": 0.6,
    "chat.editor.wordWrap": "on",
    "editor.wordWrap": "on",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "cSpell.userWords": [
        "Domuwa",
        "emph",
        "ESOL",
        "HTMX",
        "Jaśkowski",
        "Keras",
        "Librosa",
        "Plotly",
        "Pydantic",
        "Pytest",
        "Qdrant",
        "Scikit",
        "Szymon",
        "Typst"
    ],
}